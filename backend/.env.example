# ============================================================
# MediSync Backend - Archivo de Configuración (.env)
# ============================================================
# Copia este archivo a .env y completa los valores

# ============================================================
# SERVIDOR
# ============================================================
PORT=4000
CLIENT_URL=http://localhost:5173

# ============================================================
# BASE DE DATOS - AWS RDS PostgreSQL
# ============================================================
# Formato: postgresql://usuario:contraseña@host:puerto/base_datos?sslmode=require
# 
# Ejemplo con AWS RDS:
# postgresql://postgres:MediSync2026!Secure@db-dyas.crepubhj4fys.us-east-1.rds.amazonaws.com:5432/medisync?sslmode=require
#
# Partes:
# - usuario: postgres (usuario por defecto de RDS)
# - contraseña: MediSync2026!Secure (configurado en AWS)
# - host: db-dyas.crepubhj4fys.us-east-1.rds.amazonaws.com (endpoint RDS)
# - puerto: 5432 (puerto PostgreSQL por defecto)
# - base_datos: medisync (nombre de la BD)
# - sslmode=require (obligatorio para AWS RDS)

DATABASE_URL="postgresql://usuario:contraseña@host:5432/medisync?sslmode=require"

# ============================================================
# JWT - Tokens de Autenticación
# ============================================================
# Generar nuevos: node generate-jwt-secrets.js
#
# Access Token: 15 minutos de duración
# Refresh Token: 7 días de duración
#
# IMPORTANTE: En producción, usar AWS Secrets Manager

JWT_ACCESS_SECRET=tu_secret_access_aqui_cambiar_en_produccion
JWT_REFRESH_SECRET=tu_secret_refresh_aqui_cambiar_en_produccion

# ============================================================
# ENTORNO
# ============================================================
# Valores: development, production, test
NODE_ENV=development

# ============================================================
# OPCIONAL - AWS (si usas S3 u otros servicios)
# ============================================================
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=tu_access_key
# AWS_SECRET_ACCESS_KEY=tu_secret_key
# AWS_S3_BUCKET=medisync-expedientes

# ============================================================
# OPCIONAL - Email (para notificaciones)
# ============================================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=tu_email@gmail.com
# SMTP_PASSWORD=tu_app_password
# SMTP_FROM=noreply@medisync.com

# ============================================================
# GUÍA DE CONFIGURACIÓN
# ============================================================
#
# 1. BASE DE DATOS (AWS RDS PostgreSQL)
#    - Ir a AWS Console → RDS → Databases
#    - Encontrar instancia "medisync"
#    - Copiar Endpoint desde "Connectivity & security"
#    - Verificar Security Group permite puerto 5432 desde tu IP
#    - Usar DATABASE_URL con formato anterior
#
# 2. JWT SECRETS
#    - Ejecutar: node generate-jwt-secrets.js
#    - Copiar valores a JWT_ACCESS_SECRET y JWT_REFRESH_SECRET
#    - En producción: guardar en AWS Secrets Manager
#    - NO versionizar en Git
#
# 3. VERIFICAR CONFIGURACIÓN
#    - Ejecutar: npm run prisma:generate
#    - Ejecutar: node verify-prisma-connection.js
#    - Debe mostrar ✅ Verificación completada exitosamente!
#
# 4. INICIAR SERVIDOR
#    - Ejecutar: npm run dev
#    - Debe mostrar: MediSync API running on http://localhost:4000
#
# ============================================================
